---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProfile, t, buildLocalizedPaths, type Locale } from '../i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { person, experience, education, certifications } = getProfile(locale);
const strings = t(locale);
const localizedPaths = buildLocalizedPaths('/experience');
const homePath = locale === 'de' ? '/de/' : '/';
const prefix = locale === 'de' ? '/de' : '';

// Maps specific experience highlight bullets to the case study that covers them in
// depth, keyed on the exact highlight text (see src/data/profile.ts / profile.de.ts).
const highlightLinks: Record<string, string> =
  locale === 'de'
    ? {
        'Initiierte und leitete ein KI-gestütztes Cross-Selling-Projekt, das die interne Cross-Selling-Logik durch ein Berechnungsmodell auf Basis von SAP-Verkaufsdaten ersetzte, um wirklich komplementäre Produktempfehlungen anzuzeigen.':
          '/case-studies/ai-cross-selling',
        'Verantwortet das Metadaten-Management auf Produktebene und leitete die Migration der Produktspezifikationsdaten von Censhare in ein neues PIM-System, wobei definiert wurde, wie Daten auf endress.com und durch KI-Tools strukturiert und genutzt werden.':
          '/case-studies/metadata-pim-migration',
        'Erweiterte die Onsite-Suche (Elasticsearch) von endress.com um eine geschäftsspezifische Boost-Schicht über deren nativen Relevanzalgorithmus, die Produktlebenszyklus-Phase, Segmentierung, Lagerverfügbarkeit und Marktverfügbarkeit berücksichtigt, um die relevantesten Listings zuerst auszuspielen.':
          '/case-studies/relevance-sorting',
        'Konzipierte und lancierte ein MVP-Feature inklusive unterstützendem Datenmanagement-Prozess, um marktspezifische Lagerverfügbarkeit auf der Website anzuzeigen, einschliesslich verfügbarer Konfigurationsvarianten.':
          '/case-studies/in-stock-mvp',
      }
    : {
        'Initiated and led an AI-powered cross-selling project, replacing internal cross-selling logic with a calculation model built on SAP sales order data to surface genuinely complementary product recommendations.':
          '/case-studies/ai-cross-selling',
        'Owns product-level metadata management and led the migration of product specification data from Censhare to a new PIM system, defining how data is structured and consumed on endress.com and by AI tools.':
          '/case-studies/metadata-pim-migration',
        "Enhanced endress.com's onsite search (Elasticsearch) with a business-tuned boost layer on top of its native relevance algorithm, factoring in product lifecycle phase, segmentation, stock availability, and market availability to surface the most relevant listings first.":
          '/case-studies/relevance-sorting',
        'Designed and launched an MVP feature plus supporting data management process to show market-level stock availability on the website, including which configuration variants are available.':
          '/case-studies/in-stock-mvp',
      };

const description = `${strings.experience.intro} ${experience
  .map((e) => `${e.title} — ${e.company}`)
  .join(', ')}.`;

const breadcrumbs = [
  { name: strings.breadcrumbs.home, path: homePath },
  { name: strings.breadcrumbs.experience, path: localizedPaths[locale] },
];
---

<BaseLayout
  title={strings.experience.title}
  description={description}
  path={localizedPaths[locale]}
  ogImageSlug={locale === 'de' ? 'de/experience' : 'experience'}
  locale={locale}
  localizedPaths={localizedPaths}
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand">{person.location}</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-ink sm:text-5xl">{strings.experience.title}</h1>
    <p class="mt-4 max-w-2xl text-base text-muted">
      {strings.experience.intro}
    </p>

    <ol class="mt-12 space-y-12 border-l border-border pl-8">
      {experience.map((role) => (
        <li class="relative">
          <span class="absolute -left-[calc(2rem+5px)] top-1.5 h-2.5 w-2.5 rounded-full bg-brand"></span>
          <h2 class="text-xl font-semibold text-ink">{role.title}</h2>
          <p class="mt-1 text-sm font-medium text-brand">{role.company}</p>
          <p class="mt-1 text-sm text-muted">{role.dates} · {role.location}</p>
          <p class="mt-4 max-w-3xl text-base leading-relaxed text-ink-soft">{role.summary}</p>
          <ul class="mt-4 space-y-2">
            {role.highlights.map((highlight) => (
              <li class="flex gap-3 text-sm leading-relaxed text-ink-soft">
                <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-border"></span>
                <span>
                  {highlight}
                  {highlightLinks[highlight] && (
                    <>
                      {' '}
                      <a
                        href={`${prefix}${highlightLinks[highlight]}`}
                        class="font-semibold text-brand hover:text-brand-dark"
                      >
                        {strings.caseStudies.readCaseStudy}
                      </a>
                    </>
                  )}
                </span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </section>

  <section class="border-t border-border bg-surface-alt">
    <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">{strings.experience.eduCertHeading}</h2>
      <div class="mt-8 grid gap-10 sm:grid-cols-2">
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-muted">{strings.experience.educationLabel}</h3>
          <ul class="mt-4 space-y-4">
            {education.map((entry) => (
              <li>
                <p class="font-semibold text-ink">{entry.degree}</p>
                <p class="mt-1 text-sm text-ink-soft">{entry.institution}, {entry.location}</p>
                <p class="text-sm text-muted">{entry.dates}</p>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-muted">{strings.experience.certificationsLabel}</h3>
          <ul class="mt-4 space-y-2">
            {certifications.map((cert) => (
              <li class="flex gap-3 text-sm text-ink-soft">
                <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-brand"></span>
                <span>{cert}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
