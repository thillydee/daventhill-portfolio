---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProfile, t, buildLocalizedPaths, type Locale } from '../i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { person, skills, leadershipApproach, languages } = getProfile(locale);
const strings = t(locale);
const localizedPaths = buildLocalizedPaths('/skills');
const homePath = locale === 'de' ? '/de/' : '/';
const prefix = locale === 'de' ? '/de' : '';

const skillLinks: Record<string, string> =
  locale === 'de'
    ? {
        'Squad- und Teamführung': '/knowledge/squad',
        'Moderation der Agile Guild': '/knowledge/guild',
        'Squad Health Checks': '/knowledge/guild',
        'UAT-Konzeption & Koordination': '/knowledge/user-acceptance-testing',
        Elasticsearch: '/case-studies/relevance-sorting',
        'Metadaten-Management': '/case-studies/metadata-pim-migration',
        'PIM (Product Information Management)': '/case-studies/metadata-pim-migration',
        'KI- und ML-gestützte Produktempfehlungen': '/case-studies/ai-cross-selling',
        'SAP-Verkaufsdaten': '/case-studies/ai-cross-selling',
      }
    : {
        'Squad and team leadership': '/knowledge/squad',
        'Agile Guild facilitation': '/knowledge/guild',
        'Squad Health Checks': '/knowledge/guild',
        'UAT design & coordination': '/knowledge/user-acceptance-testing',
        Elasticsearch: '/case-studies/relevance-sorting',
        'Metadata management': '/case-studies/metadata-pim-migration',
        'PIM (Product Information Management)': '/case-studies/metadata-pim-migration',
        'AI and ML informed product recommendations': '/case-studies/ai-cross-selling',
        'SAP sales order data': '/case-studies/ai-cross-selling',
      };

const skillGroups = [
  { label: strings.skills.groups.productAndAgile, items: skills.productAndAgile },
  { label: strings.skills.groups.dataAndAi, items: skills.dataAndAi },
  { label: strings.skills.groups.ecommerce, items: skills.ecommerce },
  { label: strings.skills.groups.tools, items: skills.tools },
];

const breadcrumbs = [
  { name: strings.breadcrumbs.home, path: homePath },
  { name: strings.breadcrumbs.skills, path: localizedPaths[locale] },
];
---

<BaseLayout
  title={strings.skills.title}
  description={strings.skills.description}
  path={localizedPaths[locale]}
  ogImageSlug={locale === 'de' ? 'de/skills' : 'skills'}
  locale={locale}
  localizedPaths={localizedPaths}
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand">{person.location}</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-ink sm:text-5xl">{strings.skills.title}</h1>

    <div id="leadership" class="mt-6 max-w-3xl scroll-mt-24 rounded-xl border border-border bg-surface p-6">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">{strings.skills.leadershipHeading}</h2>
      <p class="mt-4 text-base leading-relaxed text-ink-soft">{leadershipApproach}</p>
      <ul class="mt-4 space-y-2">
        {person.leadershipHighlights.map((highlight) => (
          <li class="flex gap-3 text-sm text-ink-soft">
            <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-brand"></span>
            <span>{highlight}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2">
      {skillGroups.map((group) => (
        <div class="rounded-xl border border-border bg-surface p-6">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-brand">{group.label}</h2>
          <ul class="mt-4 flex flex-wrap gap-2">
            {group.items.map((item) => (
              skillLinks[item] ? (
                <li>
                  <a
                    href={`${prefix}${skillLinks[item]}`}
                    class="rounded-full border border-brand/30 bg-brand-soft px-3 py-1 text-sm text-brand hover:border-brand"
                  >
                    {item}
                  </a>
                </li>
              ) : (
                <li class="rounded-full border border-border bg-surface-alt px-3 py-1 text-sm text-ink-soft">
                  {item}
                </li>
              )
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="border-t border-border bg-surface-alt">
    <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">{strings.skills.languagesHeading}</h2>
      <ul class="mt-6 flex flex-wrap gap-3">
        {languages.map((lang) => (
          <li class="rounded-full border border-border bg-surface px-4 py-2 text-sm text-ink-soft">
            <span class="font-semibold text-ink">{lang.language}</span> · {lang.level}
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
