---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, buildLocalizedPaths, type Locale } from '../i18n';
import type { CaseStudy } from '../data/profile';

export interface Props {
  locale: Locale;
  caseStudy: CaseStudy;
}

const { locale, caseStudy } = Astro.props;
const strings = t(locale);
const localizedPaths = buildLocalizedPaths(`/case-studies/${caseStudy.slug}`);
const homePath = locale === 'de' ? '/de/' : '/';
const prefix = locale === 'de' ? '/de' : '';
const caseStudiesPath = `${prefix}/case-studies`;

const knowledgeEntries = await getCollection(locale === 'de' ? 'knowledgeDe' : 'knowledgeEn');
const relatedKnowledge = knowledgeEntries.filter((entry) =>
  entry.data.relatedCaseStudies?.includes(caseStudy.slug),
);

const breadcrumbs = [
  { name: strings.breadcrumbs.home, path: homePath },
  { name: strings.breadcrumbs.caseStudies, path: caseStudiesPath },
  { name: caseStudy.title, path: localizedPaths[locale] },
];
---

<BaseLayout
  title={caseStudy.title}
  description={caseStudy.summary}
  path={localizedPaths[locale]}
  ogImageSlug={locale === 'de' ? `de/case-studies/${caseStudy.slug}` : `case-studies/${caseStudy.slug}`}
  locale={locale}
  localizedPaths={localizedPaths}
  breadcrumbs={breadcrumbs}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <a href={caseStudiesPath} class="text-sm font-semibold text-brand hover:text-brand-dark">
      {strings.caseStudyDetail.back}
    </a>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-ink sm:text-4xl">{caseStudy.title}</h1>
    <p class="mt-4 text-lg text-ink-soft">{caseStudy.summary}</p>

    <div class="mt-10 space-y-10">
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-brand">{strings.caseStudyDetail.problem}</h2>
        <p class="mt-3 text-base leading-relaxed text-ink-soft">{caseStudy.problem}</p>
      </div>
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-brand">{strings.caseStudyDetail.approach}</h2>
        <p class="mt-3 text-base leading-relaxed text-ink-soft">{caseStudy.approach}</p>
      </div>
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wide text-brand">{strings.caseStudyDetail.outcome}</h2>
        <p class="mt-3 text-base leading-relaxed text-ink-soft">{caseStudy.outcome}</p>
      </div>
    </div>

    {relatedKnowledge.length > 0 && (
      <div class="mt-16">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">
          {strings.caseStudyDetail.relatedKnowledgeHeading}
        </h2>
        <ul class="mt-4 space-y-2">
          {relatedKnowledge.map((entry) => (
            <li>
              <a
                href={`${prefix}/knowledge/${entry.id}`}
                class="text-sm font-semibold text-brand hover:text-brand-dark"
              >
                {entry.data.title} →
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <div class="mt-16 rounded-xl border border-border bg-surface-alt p-8 text-center">
      <h2 class="text-xl font-semibold text-ink">{strings.caseStudyDetail.ctaHeading}</h2>
      <p class="mt-2 text-sm text-muted">
        {strings.caseStudyDetail.ctaText}
      </p>
      <a
        href={`${prefix}/contact`}
        class="mt-5 inline-flex items-center justify-center rounded-md bg-brand px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-dark"
      >
        {strings.caseStudyDetail.ctaButton}
      </a>
    </div>
  </article>
</BaseLayout>
