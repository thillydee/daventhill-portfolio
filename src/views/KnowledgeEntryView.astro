---
import { render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import type { FaqItem } from '../components/PersonSchema.astro';
import { getProfile, t, buildLocalizedPaths, type Locale } from '../i18n';

export interface Props {
  locale: Locale;
  entry: CollectionEntry<'knowledgeEn'> | CollectionEntry<'knowledgeDe'>;
}

const { locale, entry } = Astro.props;
const strings = t(locale);
const { caseStudies } = getProfile(locale);
const localizedPaths = buildLocalizedPaths(`/knowledge/${entry.id}`);
const homePath = locale === 'de' ? '/de/' : '/';
const prefix = locale === 'de' ? '/de' : '';
const knowledgePath = `${prefix}/knowledge`;

const { Content } = await render(entry);

const breadcrumbs = [
  { name: strings.breadcrumbs.home, path: homePath },
  { name: strings.breadcrumbs.knowledge, path: knowledgePath },
  { name: entry.data.title, path: localizedPaths[locale] },
];

const related = (entry.data.relatedCaseStudies ?? [])
  .map((slug) => caseStudies.find((cs) => cs.slug === slug))
  .filter((cs) => cs !== undefined);

const publishedLabel = new Intl.DateTimeFormat(locale === 'de' ? 'de-CH' : 'en-CH', {
  dateStyle: 'long',
}).format(entry.data.publishDate);

const embeddedFaqs = entry.data.faqs;
const primaryFaq: FaqItem | undefined =
  entry.data.type === 'faq' && entry.data.question
    ? { question: entry.data.question, answer: entry.data.description }
    : undefined;
const faqItems: FaqItem[] | undefined = primaryFaq
  ? [primaryFaq, ...(embeddedFaqs ?? [])]
  : embeddedFaqs && embeddedFaqs.length > 0
    ? embeddedFaqs
    : undefined;
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  path={localizedPaths[locale]}
  ogImageSlug={locale === 'de' ? `de/knowledge/${entry.id}` : `knowledge/${entry.id}`}
  locale={locale}
  localizedPaths={localizedPaths}
  breadcrumbs={breadcrumbs}
  publishDate={entry.data.publishDate}
  definedTerm={
    entry.data.type === 'concept'
      ? { name: entry.data.title, description: entry.data.description }
      : undefined
  }
  faq={faqItems}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <a href={knowledgePath} class="text-sm font-semibold text-brand hover:text-brand-dark">
      {strings.knowledge.back}
    </a>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-ink sm:text-4xl">
      {entry.data.type === 'faq' ? entry.data.question ?? entry.data.title : entry.data.title}
    </h1>
    <p class="mt-4 text-lg text-ink-soft">{entry.data.description}</p>
    <p class="mt-4 text-xs uppercase tracking-wide text-muted">
      {strings.knowledge.publishedLabel}{' '}
      <time datetime={entry.data.publishDate.toISOString()}>{publishedLabel}</time>
    </p>

    <div class="prose prose-slate mt-10 max-w-none prose-headings:font-semibold prose-headings:text-ink prose-p:leading-relaxed prose-p:text-ink-soft prose-a:text-brand">
      <Content />
    </div>

    {embeddedFaqs && embeddedFaqs.length > 0 && (
      <div class="mt-12">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">
          {strings.knowledge.faqSectionHeading}
        </h2>
        <dl class="mt-4 space-y-6">
          {embeddedFaqs.map((item) => (
            <div>
              <dt class="text-base font-semibold text-ink">{item.question}</dt>
              <dd class="mt-2 max-w-3xl text-sm leading-relaxed text-ink-soft">{item.answer}</dd>
            </div>
          ))}
        </dl>
      </div>
    )}

    {related.length > 0 && (
      <div class="mt-16 rounded-xl border border-border bg-surface-alt p-8">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">
          {strings.knowledge.relatedCaseStudiesHeading}
        </h2>
        <ul class="mt-4 space-y-2">
          {related.map((cs) => (
            <li>
              <a href={`${prefix}/case-studies/${cs!.slug}`} class="text-sm font-semibold text-brand hover:text-brand-dark">
                {cs!.title} →
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </article>
</BaseLayout>
