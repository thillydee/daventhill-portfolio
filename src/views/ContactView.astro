---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProfile, t, buildLocalizedPaths, type Locale } from '../i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { person } = getProfile(locale);
const strings = t(locale);
const localizedPaths = buildLocalizedPaths('/contact');
const homePath = locale === 'de' ? '/de/' : '/';
const telHref = person.contact.phone.replace(/\s+/g, '');
const cvHref = locale === 'de' ? '/cv/Daven-Thill-CV-DE.pdf' : '/cv/Daven-Thill-CV-EN.pdf';

const breadcrumbs = [
  { name: strings.breadcrumbs.home, path: homePath },
  { name: strings.breadcrumbs.contact, path: localizedPaths[locale] },
];

const formStrings = strings.contact.form;
---

<BaseLayout
  title={strings.contact.title}
  description={strings.contact.description}
  path={localizedPaths[locale]}
  ogImageSlug={locale === 'de' ? 'de/contact' : 'contact'}
  locale={locale}
  localizedPaths={localizedPaths}
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand">{person.location}</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-ink sm:text-5xl">{strings.contact.heading}</h1>
    <p class="mt-4 max-w-2xl text-base text-muted">
      {strings.contact.intro}
    </p>

    <div class="mt-12 grid gap-12 sm:grid-cols-5">
      <form id="contact-form" class="sm:col-span-3" novalidate>
        <div class="grid gap-5">
          <div>
            <label for="name" class="text-sm font-semibold text-ink">{formStrings.name}</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-1.5 w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            />
          </div>
          <div>
            <label for="email" class="text-sm font-semibold text-ink">{formStrings.email}</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-1.5 w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            />
          </div>
          <div>
            <label for="company" class="text-sm font-semibold text-ink">
              {formStrings.company} <span class="font-normal text-muted">{formStrings.optional}</span>
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="mt-1.5 w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            />
          </div>
          <div>
            <label for="message" class="text-sm font-semibold text-ink">{formStrings.message}</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="mt-1.5 w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            ></textarea>
          </div>
          <div class="hidden" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <button
            type="submit"
            class="inline-flex w-fit items-center justify-center rounded-md bg-brand px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-dark disabled:cursor-not-allowed disabled:opacity-60"
          >
            {formStrings.send}
          </button>
          <p
            id="form-status"
            class="text-sm"
            role="status"
            aria-live="polite"
            data-sending={formStrings.sending}
            data-success={formStrings.success}
            data-error={formStrings.error}
          ></p>
        </div>
      </form>

      <div class="sm:col-span-2">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">{strings.contact.directContact}</h2>
        <ul class="mt-4 space-y-3 text-sm text-ink-soft">
          <li>
            <a href={`mailto:${person.contact.email}`} class="hover:text-brand">
              {person.contact.email}
            </a>
          </li>
          <li>
            <a href={`tel:${telHref}`} class="hover:text-brand">{person.contact.phone}</a>
          </li>
          <li>
            <a href={person.contact.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-brand">
              LinkedIn
            </a>
          </li>
          <li>
            <a href={person.contact.github} target="_blank" rel="noopener noreferrer" class="hover:text-brand">
              GitHub
            </a>
          </li>
        </ul>
        <p class="mt-6 text-sm text-muted">{person.nationality}</p>
        <a
          href={cvHref}
          download
          data-analytics-event="cv_download"
          data-analytics-locale={locale}
          class="mt-6 inline-flex items-center justify-center rounded-md border border-border px-5 py-3 text-sm font-semibold text-ink transition-colors hover:border-brand hover:text-brand"
        >
          {strings.nav.downloadCv}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { track } from '@vercel/analytics';

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;
  const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  form.addEventListener('submit', async (event) => {
    event.preventDefault();

    submitButton.disabled = true;
    status.textContent = status.dataset.sending ?? '';
    status.className = 'text-sm text-muted';

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error('Request failed');
      }

      form.reset();
      status.textContent = status.dataset.success ?? '';
      status.className = 'text-sm text-green-700';
      track('contact_form_submit', { locale: document.documentElement.lang });
    } catch (error) {
      status.textContent = status.dataset.error ?? '';
      status.className = 'text-sm text-red-700';
    } finally {
      submitButton.disabled = false;
    }
  });
</script>
