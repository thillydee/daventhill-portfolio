---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t, buildLocalizedPaths, type Locale } from '../i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const localizedPaths = buildLocalizedPaths('/privacy');
const homePath = locale === 'de' ? '/de/' : '/';

const breadcrumbs = [
  { name: strings.breadcrumbs.home, path: homePath },
  { name: strings.breadcrumbs.privacy, path: localizedPaths[locale] },
];
---

<BaseLayout
  title={strings.privacy.title}
  description={strings.privacy.description}
  path={localizedPaths[locale]}
  ogImageSlug={locale === 'de' ? 'de/privacy' : 'privacy'}
  locale={locale}
  localizedPaths={localizedPaths}
  breadcrumbs={breadcrumbs}
>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">{strings.privacy.title}</h1>
    <p class="mt-4 text-lg text-ink-soft">{strings.privacy.intro}</p>

    <div class="mt-10 space-y-10">
      {strings.privacy.sections.map((section) => (
        <div>
          <h2 class="text-sm font-semibold uppercase tracking-wide text-brand">{section.heading}</h2>
          <p class="mt-3 text-base leading-relaxed text-ink-soft">{section.body}</p>
        </div>
      ))}
    </div>
  </article>
</BaseLayout>
