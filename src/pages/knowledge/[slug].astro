---
import { getCollection } from 'astro:content';
import KnowledgeEntryView from '../../views/KnowledgeEntryView.astro';

export async function getStaticPaths() {
  const entries = await getCollection('knowledgeEn');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
---

<KnowledgeEntryView locale="en" entry={entry} />
