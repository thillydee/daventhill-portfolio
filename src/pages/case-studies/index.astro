---
import BaseLayout from '../../layouts/BaseLayout.astro';
import profile from '../../data/profile';

const { caseStudies, person } = profile;

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Case Studies', path: '/case-studies' },
];
---

<BaseLayout
  title="Case Studies"
  description="Data and AI driven product case studies from Daven Thill's work on endress.com, covering cross-selling, PIM data, relevance sorting, and stock availability."
  path="/case-studies"
  ogImageSlug="case-studies"
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand">{person.location}</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-ink sm:text-5xl">Case Studies</h1>
    <p class="mt-4 max-w-2xl text-base text-muted">
      A closer look at data- and AI-driven product decisions from {person.name}'s work leading the
      Products section of endress.com.
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2">
      {caseStudies.map((caseStudy) => (
        <a
          href={`/case-studies/${caseStudy.slug}`}
          class="group rounded-xl border border-border bg-surface p-6 transition-colors hover:border-brand"
        >
          <h2 class="text-lg font-semibold text-ink group-hover:text-brand">{caseStudy.title}</h2>
          <p class="mt-2 text-sm leading-relaxed text-muted">{caseStudy.summary}</p>
          <span class="mt-4 inline-block text-sm font-semibold text-brand">Read case study →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
