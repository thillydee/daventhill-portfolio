---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile';

const { person, experience, education, certifications } = profile;

const description = `Professional experience of ${person.name}, ${person.currentTitle} in Basel: ${experience
  .map((e) => `${e.title} at ${e.company}`)
  .join(', ')}.`;

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Experience', path: '/experience' },
];
---

<BaseLayout
  title="Experience"
  description={description}
  path="/experience"
  ogImageSlug="experience"
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand">{person.location}</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-ink sm:text-5xl">Experience</h1>
    <p class="mt-4 max-w-2xl text-base text-muted">
      More than five years leading digital products end to end, from roadmap and backlog to
      hands-on delivery in B2B and industrial environments.
    </p>

    <ol class="mt-12 space-y-12 border-l border-border pl-8">
      {experience.map((role) => (
        <li class="relative">
          <span class="absolute -left-[calc(2rem+5px)] top-1.5 h-2.5 w-2.5 rounded-full bg-brand"></span>
          <h2 class="text-xl font-semibold text-ink">{role.title}</h2>
          <p class="mt-1 text-sm font-medium text-brand">{role.company}</p>
          <p class="mt-1 text-sm text-muted">{role.dates} · {role.location}</p>
          <p class="mt-4 max-w-3xl text-base leading-relaxed text-ink-soft">{role.summary}</p>
          <ul class="mt-4 space-y-2">
            {role.highlights.map((highlight) => (
              <li class="flex gap-3 text-sm leading-relaxed text-ink-soft">
                <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-border"></span>
                <span>{highlight}</span>
              </li>
            ))}
          </ul>
        </li>
      ))}
    </ol>
  </section>

  <section class="border-t border-border bg-surface-alt">
    <div class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
      <h2 class="text-2xl font-bold text-ink sm:text-3xl">Education & certifications</h2>
      <div class="mt-8 grid gap-10 sm:grid-cols-2">
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-muted">Education</h3>
          <ul class="mt-4 space-y-4">
            {education.map((entry) => (
              <li>
                <p class="font-semibold text-ink">{entry.degree}</p>
                <p class="mt-1 text-sm text-ink-soft">{entry.institution}, {entry.location}</p>
                <p class="text-sm text-muted">{entry.dates}</p>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-muted">Certifications</h3>
          <ul class="mt-4 space-y-2">
            {certifications.map((cert) => (
              <li class="flex gap-3 text-sm text-ink-soft">
                <span class="mt-1.5 h-1.5 w-1.5 flex-none rounded-full bg-brand"></span>
                <span>{cert}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
