---
import BaseLayout from '../layouts/BaseLayout.astro';
import profile from '../data/profile';

const { person } = profile;
const telHref = person.contact.phone.replace(/\s+/g, '');

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Contact', path: '/contact' },
];
---

<BaseLayout
  title="Contact"
  description={`Get in touch with ${person.name}, ${person.currentTitle} based in Basel, Switzerland.`}
  path="/contact"
  ogImageSlug="contact"
  breadcrumbs={breadcrumbs}
>
  <section class="mx-auto max-w-5xl px-4 py-16 sm:px-6">
    <p class="text-sm font-semibold uppercase tracking-wide text-brand">{person.location}</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-ink sm:text-5xl">Get in touch</h1>
    <p class="mt-4 max-w-2xl text-base text-muted">
      Open to Product Owner roles and projects in Basel, Basel-Landschaft, and across
      Switzerland. Send a message below or reach out directly.
    </p>

    <div class="mt-12 grid gap-12 sm:grid-cols-5">
      <form id="contact-form" class="sm:col-span-3" novalidate>
        <div class="grid gap-5">
          <div>
            <label for="name" class="text-sm font-semibold text-ink">Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="mt-1.5 w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            />
          </div>
          <div>
            <label for="email" class="text-sm font-semibold text-ink">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="mt-1.5 w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            />
          </div>
          <div>
            <label for="company" class="text-sm font-semibold text-ink">
              Company <span class="font-normal text-muted">(optional)</span>
            </label>
            <input
              type="text"
              id="company"
              name="company"
              class="mt-1.5 w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            />
          </div>
          <div>
            <label for="message" class="text-sm font-semibold text-ink">Message</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="mt-1.5 w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-ink placeholder:text-muted focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
            ></textarea>
          </div>
          <div class="hidden" aria-hidden="true">
            <label for="website">Website</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <button
            type="submit"
            class="inline-flex w-fit items-center justify-center rounded-md bg-brand px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-brand-dark disabled:cursor-not-allowed disabled:opacity-60"
          >
            Send message
          </button>
          <p id="form-status" class="text-sm" role="status" aria-live="polite"></p>
        </div>
      </form>

      <div class="sm:col-span-2">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-muted">Direct contact</h2>
        <ul class="mt-4 space-y-3 text-sm text-ink-soft">
          <li>
            <a href={`mailto:${person.contact.email}`} class="hover:text-brand">
              {person.contact.email}
            </a>
          </li>
          <li>
            <a href={`tel:${telHref}`} class="hover:text-brand">{person.contact.phone}</a>
          </li>
          <li>
            <a href={person.contact.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-brand">
              LinkedIn
            </a>
          </li>
        </ul>
        <p class="mt-6 text-sm text-muted">{person.nationality}</p>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const status = document.getElementById('form-status') as HTMLParagraphElement;
  const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  form.addEventListener('submit', async (event) => {
    event.preventDefault();

    submitButton.disabled = true;
    status.textContent = 'Sending...';
    status.className = 'text-sm text-muted';

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        throw new Error('Request failed');
      }

      form.reset();
      status.textContent = "Thanks, your message is on its way. I'll get back to you soon.";
      status.className = 'text-sm text-green-700';
    } catch (error) {
      status.textContent = 'Something went wrong sending your message. Please try emailing directly instead.';
      status.className = 'text-sm text-red-700';
    } finally {
      submitButton.disabled = false;
    }
  });
</script>
