---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SEO from '../components/SEO.astro';
import PersonSchema, { type Breadcrumb, type FaqItem } from '../components/PersonSchema.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  path: string;
  ogImageSlug: string;
  breadcrumbs?: Breadcrumb[];
  faq?: FaqItem[];
}

const { title, description, path, ogImageSlug, breadcrumbs, faq } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} path={path} ogImageSlug={ogImageSlug} />
    <PersonSchema breadcrumbs={breadcrumbs} faq={faq} />
  </head>
  <body class="flex min-h-screen flex-col bg-surface font-sans text-ink antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <Analytics />
  </body>
</html>
