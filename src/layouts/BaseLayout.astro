---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SEO from '../components/SEO.astro';
import PersonSchema, {
  type Breadcrumb,
  type FaqItem,
  type DefinedTermInput,
} from '../components/PersonSchema.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { htmlLang, type Locale } from '../i18n';

export interface Props {
  title: string;
  description: string;
  path: string;
  ogImageSlug: string;
  locale: Locale;
  localizedPaths: Record<Locale, string>;
  breadcrumbs?: Breadcrumb[];
  faq?: FaqItem[];
  definedTerm?: DefinedTermInput;
}

const {
  title,
  description,
  path,
  ogImageSlug,
  locale,
  localizedPaths,
  breadcrumbs,
  faq,
  definedTerm,
} = Astro.props;
---

<html lang={htmlLang(locale)}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      path={path}
      ogImageSlug={ogImageSlug}
      locale={locale}
      localizedPaths={localizedPaths}
    />
    <PersonSchema locale={locale} breadcrumbs={breadcrumbs} faq={faq} definedTerm={definedTerm} />
  </head>
  <body class="flex min-h-screen flex-col bg-surface font-sans text-ink antialiased">
    <Header locale={locale} localizedPaths={localizedPaths} />
    {breadcrumbs && <Breadcrumbs items={breadcrumbs} />}
    <main class="flex-1">
      <slot />
    </main>
    <Footer locale={locale} />
    <Analytics />
    <script>
      import { track } from '@vercel/analytics';

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const trackedEl = target.closest('[data-analytics-event]');
        if (!(trackedEl instanceof HTMLElement)) return;

        const eventName = trackedEl.dataset.analyticsEvent;
        if (!eventName) return;

        track(eventName, { locale: trackedEl.dataset.analyticsLocale ?? '' });
      });
    </script>
  </body>
</html>
