---
import { getProfile, t, type Locale } from '../i18n';

export interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { person } = getProfile(locale);
const strings = t(locale);
const prefix = locale === 'de' ? '/de' : '';
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-surface-alt">
  <div class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-3">
      <div>
        <p class="text-base font-semibold text-ink">{person.name}</p>
        <p class="mt-1 text-sm text-muted">{person.currentTitle} · {person.location}</p>
      </div>
      <div class="flex flex-col gap-1 text-sm text-ink-soft">
        <a href={`mailto:${person.contact.email}`} class="hover:text-brand">{person.contact.email}</a>
        <a href={person.contact.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-brand">
          LinkedIn
        </a>
        <a href={person.contact.github} target="_blank" rel="noopener noreferrer" class="hover:text-brand">
          GitHub
        </a>
      </div>
      <nav aria-label="Footer navigation" class="flex flex-col gap-1 text-sm text-ink-soft">
        <a href={`${prefix}/experience`} class="hover:text-brand">{strings.nav.experience}</a>
        <a href={`${prefix}/case-studies`} class="hover:text-brand">{strings.nav.caseStudies}</a>
        <a href={`${prefix}/skills`} class="hover:text-brand">{strings.nav.skills}</a>
        <a href={`${prefix}/contact`} class="hover:text-brand">{strings.breadcrumbs.contact}</a>
      </nav>
    </div>
    <p class="mt-8 text-xs text-muted">
      © {year} {person.name}. {strings.footer.builtWith}
      {' '}·{' '}
      <a href={`${prefix}/privacy`} class="hover:text-brand">{strings.breadcrumbs.privacy}</a>
    </p>
  </div>
</footer>
