---
import { t, type Locale } from '../i18n';

export interface Props {
  locale: Locale;
  localizedPaths: Record<Locale, string>;
}

const { locale, localizedPaths } = Astro.props;
const strings = t(locale);
const prefix = locale === 'de' ? '/de' : '';

const navItems = [
  { label: strings.nav.experience, href: `${prefix}/experience` },
  { label: strings.nav.caseStudies, href: `${prefix}/case-studies` },
  { label: strings.nav.skills, href: `${prefix}/skills` },
  { label: strings.nav.knowledge, href: `${prefix}/knowledge` },
];

const homeHref = locale === 'de' ? '/de/' : '/';
const contactHref = `${prefix}/contact`;
const cvHref = locale === 'de' ? '/cv/Daven-Thill-CV-DE.pdf' : '/cv/Daven-Thill-CV-EN.pdf';
const currentPath = Astro.url.pathname;

const linkClass = (href: string) =>
  currentPath.startsWith(href) ? 'text-brand' : 'text-ink-soft hover:text-ink';

const otherLocale: Locale = locale === 'en' ? 'de' : 'en';
const switchLabel = strings.langSwitch.label;
const switchHref = localizedPaths[otherLocale];
const switchAriaLabel = locale === 'en' ? 'Switch to German' : 'Auf Englisch wechseln';
---

<header class="sticky top-0 z-50 border-b border-border bg-surface/95 backdrop-blur">
  <div class="mx-auto max-w-5xl px-4 sm:px-6">
    <input type="checkbox" id="nav-toggle" class="peer sr-only" />

    <div class="flex items-center justify-between py-4">
      <a href={homeHref} class="text-lg font-semibold tracking-tight text-ink">
        Daven Thill
      </a>

      <nav aria-label="Main navigation" class="hidden items-center gap-6 md:flex">
        {navItems.map((item) => (
          <a href={item.href} class:list={['text-sm font-medium', linkClass(item.href)]}>
            {item.label}
          </a>
        ))}
        <a
          href={cvHref}
          download
          data-analytics-event="cv_download"
          data-analytics-locale={locale}
          class="text-sm font-medium text-ink-soft hover:text-ink"
        >
          {strings.nav.downloadCv}
        </a>
        <a
          href={switchHref}
          class="text-sm font-medium text-ink-soft hover:text-ink"
          aria-label={switchAriaLabel}
        >
          {switchLabel}
        </a>
        <a
          href={contactHref}
          class="inline-flex items-center justify-center rounded-md bg-brand px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-dark"
        >
          {strings.nav.talk}
        </a>
      </nav>

      <label
        for="nav-toggle"
        class="cursor-pointer rounded-md p-2 text-ink peer-focus-visible:ring-2 peer-focus-visible:ring-brand md:hidden"
        aria-label="Toggle navigation menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="7" x2="20" y2="7"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
          <line x1="4" y1="17" x2="20" y2="17"></line>
        </svg>
      </label>
    </div>

    <nav
      aria-label="Mobile navigation"
      class="hidden flex-col items-start gap-1 border-t border-border py-4 peer-checked:flex md:hidden"
    >
      {navItems.map((item) => (
        <a href={item.href} class:list={['w-full py-2 text-sm font-medium', linkClass(item.href)]}>
          {item.label}
        </a>
      ))}
      <a
        href={cvHref}
        download
        data-analytics-event="cv_download"
        data-analytics-locale={locale}
        class="w-full py-2 text-sm font-medium text-ink-soft hover:text-ink"
      >
        {strings.nav.downloadCv}
      </a>
      <a href={switchHref} class="w-full py-2 text-sm font-medium text-ink-soft hover:text-ink">
        {switchLabel} — {strings.langSwitch.full}
      </a>
      <a
        href={contactHref}
        class="mt-2 inline-flex w-full items-center justify-center rounded-md bg-brand px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-dark"
      >
        {strings.nav.talk}
      </a>
    </nav>
  </div>
</header>
