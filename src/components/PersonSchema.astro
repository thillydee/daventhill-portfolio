---
import { getProfile, htmlLang, type Locale } from '../i18n';

export interface Breadcrumb {
  name: string;
  path: string;
}

export interface FaqItem {
  question: string;
  answer: string;
}

export interface DefinedTermInput {
  name: string;
  description: string;
}

export interface Props {
  locale: Locale;
  breadcrumbs?: Breadcrumb[];
  faq?: FaqItem[];
  definedTerm?: DefinedTermInput;
  publishDate?: Date;
  asProfilePage?: boolean;
}

const { locale, breadcrumbs, faq, definedTerm, publishDate, asProfilePage } = Astro.props;
const profile = getProfile(locale);
const { person, experience } = profile;

const personNode = {
  '@type': 'Person',
  '@id': `${Astro.site}#person`,
  name: person.name,
  jobTitle: person.currentTitle,
  description: person.bioShortSchema,
  url: Astro.site,
  inLanguage: htmlLang(locale),
  email: `mailto:${person.contact.email}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Basel',
    addressRegion: 'Basel-Landschaft',
    addressCountry: 'CH',
  },
  sameAs: [person.contact.linkedin, person.contact.github],
  worksFor: {
    '@type': 'Organization',
    name: experience[0].company,
  },
  knowsLanguage: profile.languages.map((l) => l.language),
};

const graph: Record<string, unknown>[] = [personNode];

if (asProfilePage) {
  graph.push({
    '@type': 'ProfilePage',
    '@id': `${Astro.site}#profilepage`,
    name: `${person.name} — ${person.currentTitle}`,
    inLanguage: htmlLang(locale),
    mainEntity: { '@id': personNode['@id'] },
  });
}

if (breadcrumbs && breadcrumbs.length > 0) {
  graph.push({
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.name,
      item: new URL(crumb.path, Astro.site).toString(),
    })),
  });
}

if (definedTerm) {
  graph.push({
    '@type': 'DefinedTerm',
    name: definedTerm.name,
    description: definedTerm.description,
    inDefinedTermSet: `${Astro.site}knowledge/`,
    author: { '@id': personNode['@id'] },
    ...(publishDate ? { datePublished: publishDate.toISOString() } : {}),
  });
}

if (faq && faq.length > 0) {
  graph.push({
    '@type': 'FAQPage',
    author: { '@id': personNode['@id'] },
    ...(publishDate ? { datePublished: publishDate.toISOString() } : {}),
    mainEntity: faq.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  });
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph,
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
